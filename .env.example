# Copy this file to .env and fill in your values.
# Never commit .env to version control.

SWAGGER_ENABLED=false

# DATABASE (used by the API; prefix DATABASE_ maps to Database struct)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_DBNAME=vna
DATABASE_USER=db-user
DATABASE_PASSWORD=db-password

# CHAT SERVER (prefix CHAT_SERVER_ maps to ChatServer struct)
CHAT_SERVER_BASE_URL=http://localhost:18789
CHAT_SERVER_AUTH_TOKEN=your-auth-token
CHAT_SERVER_MODEL=your-model

# AUTH (prefix AUTH_ maps to Auth struct)
AUTH_JWT_SECRET=change-me-to-a-long-random-secret
AUTH_JWT_ACCESS_TTL=15m
AUTH_JWT_REFRESH_TTL=720h
