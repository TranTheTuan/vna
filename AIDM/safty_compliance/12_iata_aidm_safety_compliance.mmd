        VARCHAR20  flightStatus
    }

    CREW_MEMBER {
        VARCHAR30  crewMemberID        PK
        VARCHAR3   airlineCode         FK
        VARCHAR50  firstName
        VARCHAR50  lastName
        VARCHAR20  crewType
        VARCHAR30  crewRank
    }

    DEFECT_RECORD {
        VARCHAR30  defectID            PK
