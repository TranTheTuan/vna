erDiagram

    %% ══════════════════════════════════════════
    %% UPSTREAM DOMAIN ENTITIES (FK references)
    %% ══════════════════════════════════════════

    AIRLINE {
        VARCHAR3   airlineCode         PK
        VARCHAR100 airlineName
        BOOLEAN    allianceMember
    }

    ROUTE {
        VARCHAR30  routeID                PK
        VARCHAR30  routeNetworkID         FK
        VARCHAR3   originAirportCode      FK
        VARCHAR3   destinationAirportCode FK
        VARCHAR20  routeStatus
    }

    OFFER {
        VARCHAR30   offerID             PK
        VARCHAR3    airlineCode         FK
        VARCHAR30   offerType
        VARCHAR20   status
    }

    LOYALTY_PROGRAMME {
        VARCHAR30  loyaltyProgrammeID   PK
        VARCHAR3   airlineCode          FK
        VARCHAR100 programmeName
        VARCHAR20  status
    }

    FREQUENT_FLYER_PARTNER {
        VARCHAR30  ffpPartnerID         PK
        VARCHAR3   sponsorAirlineCode   FK
        VARCHAR3   partnerAirlineCode   FK
        VARCHAR100 programName
    }

    FARE_FAMILY {
        VARCHAR30  fareFamilyID         PK
        VARCHAR30  productCatalogueID   FK
        VARCHAR3   airlineCode          FK
        VARCHAR10  fareFamilyCode
        VARCHAR10  cabinClass
    }

    ANCILLARY_SERVICE {
        VARCHAR30   ancillaryServiceID  PK
        VARCHAR30   productCatalogueID  FK
        VARCHAR3    airlineCode         FK
        VARCHAR10   serviceCode
        VARCHAR30   serviceCategory
    }

    PRODUCT_CATALOGUE {
        VARCHAR30  productCatalogueID   PK
        VARCHAR3   airlineCode          FK
        VARCHAR100 productName
        VARCHAR30  productCategory
    }

    %% ══════════════════════════════════════════
    %% DOMAIN 04 — SALES ENTITIES
    %% ══════════════════════════════════════════

    SALES_CHANNEL {
        VARCHAR30  salesChannelID       PK
        VARCHAR3   airlineCode          FK
        VARCHAR10  channelCode
        VARCHAR100 channelName
        VARCHAR30  channelType
        VARCHAR20  distributionType
        CHAR1      commissionable
        CHAR1      ndc_enabled
        VARCHAR20  status
        DATE       effectiveDate
        DATE       expiryDate
    }

    TRAVEL_AGENCY {
        VARCHAR30  travelAgencyID       PK
        VARCHAR3   airlineCode          FK
        VARCHAR30  salesChannelID       FK
        VARCHAR8   iataAgencyCode
        VARCHAR100 agencyName
        VARCHAR20  agencyType
        VARCHAR3   country
        VARCHAR50  city
        VARCHAR10  gdsCode
        VARCHAR20  accreditationStatus
        DATE       effectiveDate
        DATE       expiryDate
    }

    COMMISSION_AGREEMENT {
        VARCHAR30   commissionAgreementID PK
        VARCHAR3    airlineCode           FK
        VARCHAR30   travelAgencyID        FK
        VARCHAR30   salesChannelID        FK
        VARCHAR20   commissionType
        VARCHAR20   commissionBasis
        DECIMAL5_2  commissionRate
        DECIMAL10_2 flatAmount
        CHAR3       currency
        DATE        effectiveDate
        DATE        expiryDate
        VARCHAR20   status
    }

    BOOKING {
        VARCHAR30   bookingID            PK
        VARCHAR6    pnrCode
        VARCHAR3    airlineCode          FK
        VARCHAR30   salesChannelID       FK
        VARCHAR30   travelAgencyID       FK
        VARCHAR30   offerID              FK
        VARCHAR30   loyaltyProgrammeID   FK
        VARCHAR20   bookingStatus
        TIMESTAMP   bookingDateTime
        INTEGER     passengerCount
        DECIMAL12_2 totalFareAmount
        DECIMAL12_2 totalTaxAmount
        DECIMAL12_2 totalAmount
        CHAR3       currency
        TIMESTAMP   lastModifiedDateTime
    }

    BOOKING_SEGMENT {
        VARCHAR30   bookingSegmentID         PK
        VARCHAR30   bookingID                FK
        VARCHAR30   routeID                  FK
        VARCHAR30   fareFamilyID             FK
        VARCHAR10   flightNumber
        VARCHAR3    operatingCarrierCode
        VARCHAR3    marketingCarrierCode
        TIMESTAMP   departureDateTime
        TIMESTAMP   arrivalDateTime
        VARCHAR3    originAirportCode
        VARCHAR3    destinationAirportCode
        VARCHAR2    bookingClass
        VARCHAR1    cabinCode
        VARCHAR10   segmentStatus
        VARCHAR20   fareBasisCode
        DECIMAL10_2 segmentFareAmount
        CHAR3       currency
        INTEGER     sequenceNumber
    }

    TICKET {
        VARCHAR30   ticketID             PK
        VARCHAR30   bookingID            FK
        VARCHAR3    airlineCode          FK
        VARCHAR30   ffpPartnerID         FK
        VARCHAR14   ticketNumber
        VARCHAR10   ticketType
        VARCHAR100  passengerName
        VARCHAR5    passengerType
        TIMESTAMP   issuanceDateTime
        VARCHAR3    issuanceCountry
        VARCHAR30   issuanceChannel
        VARCHAR20   ticketStatus
        DECIMAL12_2 baseFareAmount
        DECIMAL12_2 taxAmount
        DECIMAL12_2 totalAmount
        CHAR3       currency
        INTEGER     couponCount
    }

    TICKET_COUPON {
        VARCHAR30   couponID            PK
        VARCHAR30   ticketID            FK
        VARCHAR30   bookingSegmentID    FK
        INTEGER     couponNumber
        VARCHAR10   couponStatus
        DECIMAL10_2 flightCouponValue
        CHAR3       currency
        CHAR1       boardingPassIssued
    }

    PAYMENT {
        VARCHAR30   paymentID           PK
        VARCHAR30   bookingID           FK
        VARCHAR30   loyaltyProgrammeID  FK
        VARCHAR20   paymentMethod
        VARCHAR20   paymentStatus
        DECIMAL12_2 paymentAmount
        CHAR3       currency
        VARCHAR50   transactionReference
        TIMESTAMP   paymentDateTime
        VARCHAR20   cardType
        CHAR4       cardLastFour
        INTEGER     milesUsed
    }

    BOOKING_ANCILLARY {
        VARCHAR30   bookingAncillaryID  PK
        VARCHAR30   bookingSegmentID    FK
        VARCHAR30   ancillaryServiceID  FK
        VARCHAR30   productCatalogueID  FK
        INTEGER     quantity
        DECIMAL10_2 unitPrice
        DECIMAL10_2 totalPrice
        CHAR3       currency
        VARCHAR20   ancillaryStatus
        VARCHAR4    ssrCode
        VARCHAR20   deliveryStatus
    }

    %% ══════════════════════════════════════════
    %% RELATIONSHIPS — Internal Sales Domain
    %% ══════════════════════════════════════════

    SALES_CHANNEL       ||--o{ TRAVEL_AGENCY          : "accredits"
    TRAVEL_AGENCY       ||--o{ COMMISSION_AGREEMENT   : "subject to"
    SALES_CHANNEL       ||--o{ COMMISSION_AGREEMENT   : "governed by"
    BOOKING             ||--|{ BOOKING_SEGMENT         : "contains"
    BOOKING             ||--|{ TICKET                  : "issues"
    BOOKING             ||--|{ PAYMENT                 : "settled by"
    TICKET              ||--|{ TICKET_COUPON           : "contains"
    BOOKING_SEGMENT     ||--o{ TICKET_COUPON           : "fulfilled by"
    BOOKING_SEGMENT     ||--o{ BOOKING_ANCILLARY       : "includes"

    %% ══════════════════════════════════════════
    %% RELATIONSHIPS — Cross-Domain
    %% ══════════════════════════════════════════

    AIRLINE             ||--o{ SALES_CHANNEL           : "distributes via"
    AIRLINE             ||--o{ TRAVEL_AGENCY           : "contracts"
    AIRLINE             ||--o{ COMMISSION_AGREEMENT    : "sets"
    AIRLINE             ||--o{ BOOKING                 : "holds"
    AIRLINE             ||--o{ TICKET                  : "validates"
    OFFER               ||--o{ BOOKING                 : "referenced in"
    LOYALTY_PROGRAMME   ||--o{ BOOKING                 : "accrues to"
    LOYALTY_PROGRAMME   ||--o{ PAYMENT                 : "redeemed in"
    ROUTE               ||--o{ BOOKING_SEGMENT         : "operated on"
    FARE_FAMILY         ||--o{ BOOKING_SEGMENT         : "priced under"
    ANCILLARY_SERVICE   ||--o{ BOOKING_ANCILLARY       : "sold as"
    PRODUCT_CATALOGUE   ||--o{ BOOKING_ANCILLARY       : "references"
    FREQUENT_FLYER_PARTNER ||--o{ TICKET               : "credits miles via"
